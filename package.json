{
  "name": "notion-equation",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Build and release tooling for the Notion Equation Chrome extension.",
  "scripts": {
    "build": "node scripts/build.mjs",
    "dev": "node scripts/build.mjs --watch",
    "typecheck": "tsc --noEmit",
    "test": "node scripts/test.mjs",
    "verify": "node scripts/verify-build.mjs",
    "verify:store": "node scripts/verify-store-assets.mjs",
    "check": "npm run typecheck && npm test && npm run build && npm run verify && npm run verify:store",
    "package": "npm run check && node scripts/package.mjs"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@types/chrome": "^0.1.4",
    "@types/node": "^24.0.3",
    "esbuild": "^0.25.5",
    "fflate": "^0.8.2",
    "typescript": "^5.8.3"
  }
}
